REFRESH_TOKEN_EXPIRE_DAYS=30
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
REFRESH_COOKIE_NAME=refresh_token

FRONTEND_URL=http://localhost:3000
RESEND_API_KEY=
DOCUMENT_WORKER_CONCURRENCY=4

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
